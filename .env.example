# Docker Compose local development environment variables.
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.

# Azure App Configuration connection string
APPCONFIG_CONNSTR=Endpoint=https://sportdeetsappconfig2.azconfig.io;Id=...;Secret=...

# PostgreSQL connection string (host.docker.internal resolves to your host machine)
PG_CONNSTR=Host=host.docker.internal;Port=5432;Username=postgres;Password=YOUR_PASSWORD_HERE

# Azure service principal used by DefaultAzureCredential to resolve Key Vault
# references that come through Azure AppConfig. Mirrors the prod k3s `azure-identity`
# secret (see sports-data-config/app/base/apps/api/api-deployment.yaml).
# Create a dedicated dev SP with "Key Vault Secrets User" on your vault.
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
